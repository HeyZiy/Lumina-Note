#!/usr/bin/env bash
# Pre-commit hook: block macos-private-api in global [dependencies].

if git diff --cached --name-only | grep -q 'src-tauri/Cargo.toml'; then
  # Check the staged version of the file
  git show :src-tauri/Cargo.toml | \
    awk '/^\[dependencies\]$/{f=1; next} /^\[/{f=0} f' | \
    grep -q 'macos-private-api' && {
      echo "ERROR: macos-private-api found in global [dependencies] of src-tauri/Cargo.toml"
      echo "This feature must only appear under [target.'cfg(target_os = \"macos\")'.dependencies]."
      echo "rust-analyzer on macOS likely merged it — please revert with:"
      echo "  git checkout src-tauri/Cargo.toml"
      exit 1
    }
fi
